{
  "name": "self_improver",
  "version": "1.0.0",
  "description": "Plector 自我改进技能 - 使用多角色协作方式完成系统升级和优化。当用户说「自我改进」、「系统升级」、「自动优化」时使用。返回格式：{success, data, error}",
  "tier": "tier_3_advanced",
  "dependencies": ["agency_orchestrator"],
  "events_produced": ["upgrade.started", "upgrade.progress", "upgrade.completed"],
  "events_consumed": ["upgrade.requested", "self_improve.trigger"],
  "tools": [
    {
      "name": "start_upgrade",
      "description": "启动 Plector 自我改进流程。参数：plan_file(升级方案路径), phase(起始阶段), max_iterations(最大迭代次数)。返回：{success, data, error}",
      "inputSchema": {
        "type": "object",
        "properties": {
          "plan_file": {
            "type": "string",
            "description": "升级方案文档路径",
            "default": "docs/reports/upgrade_plan_v2.0_integrated.md"
          },
          "phase": {
            "type": "string",
            "description": "从哪个 Phase 开始（phase_1 ~ phase_5）",
            "default": "phase_1"
          },
          "max_iterations": {
            "type": "integer",
            "description": "最大迭代轮次",
            "default": 100
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "get_status",
      "description": "查询当前升级进度和状态。返回：{success, data: {phase, progress, status}, error}",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "stop_upgrade",
      "description": "停止自我改进流程。返回：{success, data, error}",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    }
  ]
}
