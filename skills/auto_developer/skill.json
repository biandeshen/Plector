{
  "name": "auto_developer",
  "description": "一键自动开发流水线 — 从需求到代码的全自动流程。使用 agency-orchestrator 调度 174 个专家角色协作，Claude Code 执行代码开发。一句话描述需求，自动生成工作流并执行。",
  "version": "1.0.0",
  "tier": "tier_3_advanced",
  "dependencies": ["agency_orchestrator"],
  "events_produced": ["auto_develop.started"],
  "events_consumed": ["task.develop_request", "task.code_request"],
  "tools": [
    {
      "name": "develop",
      "description": "一键自动开发：需求→产品经理分析→架构师+安全工程师(并行)→高级开发者实现→代码审查→产品经理汇总。默认使用 claude-code（免 API key）。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "requirement": {
            "type": "string",
            "description": "开发需求描述，如 \"给用户模块增加批量导出 CSV 功能，要求分页、权限校验、异步处理\""
          },
          "project_dir": {
            "type": "string",
            "description": "项目目录路径（可选，默认当前目录）"
          },
          "provider": {
            "type": "string",
            "description": "LLM 提供商（默认 claude-code）"
          }
        },
        "required": ["requirement"],
        "additionalProperties": false
      }
    },
    {
      "name": "compose",
      "description": "根据需求描述自动生成工作流 YAML 文件。AI 从 174 个角色中选择合适角色、设计 DAG。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "工作流描述，如 \"PR 代码审查工作流，要覆盖安全和性能\""
          },
          "provider": {
            "type": "string",
            "description": "LLM 提供商（默认 claude-code）"
          }
        },
        "required": ["description"],
        "additionalProperties": false
      }
    },
    {
      "name": "run",
      "description": "运行指定的工作流 YAML 文件。支持 DAG 并行执行、变量传递。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string",
            "description": "工作流 YAML 文件路径"
          },
          "inputs": {
            "type": "object",
            "description": "输入变量字典"
          },
          "provider": {
            "type": "string",
            "description": "LLM 提供商（默认 claude-code）"
          }
        },
        "required": ["workflow"],
        "additionalProperties": false
      }
    },
    {
      "name": "plan",
      "description": "查看工作流的 DAG 执行计划，显示哪些步骤并行、哪些串行。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string",
            "description": "工作流 YAML 文件路径"
          }
        },
        "required": ["workflow"],
        "additionalProperties": false
      }
    },
    {
      "name": "list_roles",
      "description": "列出 agency-orchestrator 的 174 个可用 AI 角色（18 个分类）。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "可选：只列出指定分类"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "list_workflows",
      "description": "列出 32 个内置工作流模板。",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    }
  ]
}
