{
  "name": "web_search",
  "description": "网页搜索技能，使用博查 API 搜索互联网内容（国内可用）",
  "version": "1.0.0",
  "tier": "tier_2_functional",
  "dependencies": [],
  "events_produced": ["search.completed"],
  "events_consumed": [],
  "tools": [
    {
      "name": "search",
      "description": "搜索网页，返回标题、链接和摘要",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词"
          },
          "count": {
            "type": "integer",
            "description": "结果数量"
          }
        },
        "required": ["query", "count"],
        "additionalProperties": false
      }
    },
    {
      "name": "fetch_page",
      "description": "获取指定网页的文本内容",
      "inputSchema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "网页 URL"
          }
        },
        "required": ["url"],
        "additionalProperties": false
      }
    }
  ]
}
