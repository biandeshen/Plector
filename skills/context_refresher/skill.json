{
  "name": "context_refresher",
  "version": "1.0.0",
  "description": "防止长对话中 AI 遗忘初始目标，自动提取和注入 GSD 上下文",
  "tier": "tier_1_system",
  "dependencies": [],
  "events_produced": ["context.preserved", "context.re_anchored"],
  "events_consumed": ["turn.completed"],
  "tools": [
    {
      "name": "preserve",
      "description": "保鲜：从对话历史提取 GSD 上下文并存储",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "会话 ID"
          },
          "conversation_history": {
            "type": "array",
            "description": "对话历史"
          },
          "current_goal": {
            "type": "string",
            "description": "当前目标（可选）"
          }
        },
        "required": ["session_id", "conversation_history"],
        "additionalProperties": false
      }
    },
    {
      "name": "get_context",
      "description": "获取最新保鲜上下文",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "会话 ID"
          }
        },
        "required": ["session_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "re_anchor",
      "description": "重锚定：用户明确修改目标时触发",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "会话 ID"
          },
          "new_goal": {
            "type": "string",
            "description": "新的目标"
          },
          "new_constraints": {
            "type": "array",
            "items": {"type": "string"},
            "description": "新的约束条件（可选）"
          }
        },
        "required": ["session_id", "new_goal"],
        "additionalProperties": false
      }
    },
    {
      "name": "inject_context",
      "description": "注入上下文：拼接保鲜上下文 + 最近 N 轮",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "会话 ID"
          },
          "recent_turns": {
            "type": "array",
            "description": "最近对话"
          }
        },
        "required": ["session_id", "recent_turns"],
        "additionalProperties": false
      }
    }
  ]
}
